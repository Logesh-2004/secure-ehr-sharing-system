rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isClinician() {
      return signedIn()
        && exists(/databases/$(database)/documents/clinicians/$(request.auth.uid));
    }

    match /clinicians/{clinicianId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == clinicianId;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);

      match /profile/{docId} {
        allow read: if isOwner(userId) || isClinician();
        allow create, update: if isOwner(userId);
      }

      match /emergency/{docId} {
        allow read: if isOwner(userId) || isClinician();
        allow create, update: if isOwner(userId);
      }

      match /medical_records/{recordId} {
        allow read: if isOwner(userId) || isClinician();
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /qr_sessions/{sessionId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;

      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isClinician());

      allow update: if signedIn()
        && (resource.data.uid == request.auth.uid || isClinician());
    }

    match /access_logs/{logId} {
      allow create: if signedIn();
      allow read: if signedIn()
        && (resource.data.patientUid == request.auth.uid
          || resource.data.clinicianUid == request.auth.uid);
    }
  }
}
